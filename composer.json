{
    "name": "selmanozturk/flarum-ext-mobile-search",
    "description": "Move mobile search to homepage",
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [],
    "require": {
        "flarum/core": "^1.8"
    },
    "extra": {
